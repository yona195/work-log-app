# Port the API listens on (hosts usually set this automatically)
PORT=4000

# --- Database ---
# Development: leave DATABASE_URL empty to use a local SQLite file.
DATABASE_PATH=./data/work-log.db

# Production (Turso): set both of these and DATABASE_PATH is ignored.
#   turso db create work-log
#   turso db show work-log --url        -> DATABASE_URL
#   turso db tokens create work-log     -> DATABASE_AUTH_TOKEN
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# --- Auth ---
# Login is required ONLY when APP_PASSWORD is set. Leave empty in dev.
APP_PASSWORD=
# Signs session tokens. Set a long random string in production so tokens
# survive restarts (otherwise a random one is generated each start).
SESSION_SECRET=

# Legacy Google Apps Script endpoint — only for `npm run import:sheets`
SHEETS_API_URL=
